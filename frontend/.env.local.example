# Get your Google Client ID and Secret from 
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Change in deployment
NEXTAUTH_URL=http://localhost:3000

# run openssl rand -base64 32 to generate a secret key
NEXTAUTH_SECRET=some_random_string

# get your supabase url from supabase -> connect -> framework
# get your anon key from supabase -> settings -> api keys -> anon keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
